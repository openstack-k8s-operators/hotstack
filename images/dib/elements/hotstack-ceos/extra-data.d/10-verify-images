set -eu -o pipefail

if [ "${DIB_DEBUG_TRACE:-0}" -gt 0 ]; then
    set -x
fi

echo "INFO: Verifying and copying cEOS image..."

if [ -z "${DIB_CEOS_IMAGE:-}" ]; then
    echo "ERROR: DIB_CEOS_IMAGE environment variable is not set"
    echo "ERROR: Please provide the path to the cEOS tar.xz file"
    echo "ERROR: Example: DIB_CEOS_IMAGE=/path/to/cEOS64-lab-4.35.3F.tar.xz"
    exit 1
fi

if [ ! -f "${DIB_CEOS_IMAGE}" ]; then
    echo "ERROR: cEOS image file not found: ${DIB_CEOS_IMAGE}"
    exit 1
fi

echo "INFO: cEOS image verified: ${DIB_CEOS_IMAGE}"
