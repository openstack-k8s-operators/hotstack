set -eu -o pipefail

if [ "${DIB_DEBUG_TRACE:-0}" -gt 0 ]; then
    set -x
fi

if [ -z "${DIB_SONIC_IMAGE:-}" ]; then
    echo "ERROR: DIB_SONIC_IMAGE environment variable is not set"
    echo "ERROR: Please provide the path to the SONiC docker image file"
    echo "ERROR: Example: DIB_SONIC_IMAGE=/path/to/docker-sonic-vs.gz"
    exit 1
fi

if [ ! -f "${DIB_SONIC_IMAGE}" ]; then
    echo "ERROR: SONiC image file not found: ${DIB_SONIC_IMAGE}"
    exit 1
fi

echo "INFO: SONiC image verified: ${DIB_SONIC_IMAGE}"
