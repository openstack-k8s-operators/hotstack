set -Eeuo pipefail
set -x

if [ "$EUID" -eq 0 ]; then
    echo "Please do not run as root."
    exit 1
fi

NODES=
UNCORDON=
STABLE_PERIOD="2m"

function usage {
    echo "Utilities for reviving OCP snapshots"
    echo
    echo "options:"
    echo "  --wait-for-stable-cluster   Wait for cluster to be stable"
    echo "  --minimum-stable-period     Minimum cluster stable period (Default: 2m)"
    echo "  --uncordon                  Mark nodes schedulable"
    echo "  --approve-csr-signer-certs  Loop, and approve crs until cluster is up, or timeout. (Default: )"
    echo
}

SCRIPTPATH="$( cd "$(dirname "$0")" >/dev/null 2>&1 ; pwd -P )"
source "${SCRIPTPATH}"/hotstack-common-funcs.sh

function approve_csr_signer_certs {
    # local pending_csr=""
    # if ! pending_csr=$(get_pending_csrs)
    # then
    #     return 1
    # fi
    # for csr in pending_csr
    # do
    #     if ! approve_csr "${csr}"
    #     then
    #         return 1
    #     fi
    # done
    echo "TODO"
    return 0
}

while [[ "$#" -gt 0 ]]; do
    case $1 in
        "--uncordon")
            UNCORDON=True;
        ;;
        "--approve-csr-signer-certs")
            APPROVE_CSR=True;
        ;;
        "--wait-for-stable-cluster")
            STABLE_WAIT=True;
        ;;
        "--minimum-stable-period")
            STABLE_PERIOD=$2;
            shift
        ;;
        *)
            echo "Unknown parameter passed: $1";
            usage
            exit 1
        ;;
    esac
    shift
done

if [[ -z "$UNCORDON" && -z "$APPROVE_CSR" && -z "$STABLE_WAIT" ]]
then
    echo "Not enought arguments"
    usage
    exit 1
fi

if [ -n "$STABLE_WAIT"]
then
    wait_for_stable_cluster $STABLE_PERIOD || exit 1
fi

if [ -n "$UNCORDON" ]
then
    [ -z "${NODES}" ] && NODES="$(get_ocp_nodes)"
    uncordon_ocp_nodes "${NODES}" || exit 1
fi

if [ -n "$APPROVE_CSR" ]
then
    approve_csr_signer_certs
fi
